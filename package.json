    "@radix-ui/react-aspect-ratio": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.7",
    "@radix-ui/react-checkbox": "^1.2.4",
    "@radix-ui/react-collapsible": "^1.1.7",
    "@radix-ui/react-context-menu": "^2.2.11",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.11",
    "@radix-ui/react-hover-card": "^1.1.9",
    "@radix-ui/react-label": "^2.1.5",
    "@radix-ui/react-menubar": "^1.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.8",
    "@radix-ui/react-popover": "^1.1.11",
    "@radix-ui/react-progress": "^1.1.5",
    "@radix-ui/react-radio-group": "^1.2.7",
    "@radix-ui/react-scroll-area": "^1.2.7",
    "@radix-ui/react-select": "^2.1.9",
    "@radix-ui/react-separator": "^1.1.5",
    "@radix-ui/react-slider": "^1.2.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.7",
    "@radix-ui/react-toast": "^1.2.11",
    "@radix-ui/react-toggle": "^1.1.5",
    "@radix-ui/react-toggle-group": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.2.4",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.9.4",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "next-auth": "^4.24.11",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "sharp": "^0.34.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "ws": "^8.18.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
