# Database
DATABASE_URL="postgresql://futboss:changeme@localhost:5432/futboss?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Authentication
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="change-me-to-a-random-jwt-secret"

# WebSocket
WS_URL="ws://localhost:3001"
WS_PORT=3001

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="FUTBOSS"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Email (SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASSWORD=""
EMAIL_FROM="noreply@futboss.com"

# Storage
STORAGE_BUCKET="futboss-assets"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_ENABLE_LIVE_CHAT=true
NEXT_PUBLIC_ENABLE_FANTASY_LEAGUE=false

# Monitoring
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
